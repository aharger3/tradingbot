# Discord webhook URL for signal alerts
# Get from Discord server settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Discord bot token for data scraper
# Create at https://discord.com/developers/applications → New Application → Bot → Add Bot
DISCORD_DATA_TOKEN=YOUR_BOT_TOKEN_HERE

# ntfy phone-push alerts (additive to Discord). Fires only when NTFY_TOPIC is set.
# Pick an unguessable topic — anyone who knows it can read your alerts.
# Subscribe on your phone: install the ntfy app, add this topic (or open
# https://ntfy.sh/YOUR_TOPIC in a browser). Test delivery: python ntfy_notifier.py --test
NTFY_TOPIC=omen-CHANGE-ME-to-something-random
# Optional: self-hosted server (default https://ntfy.sh)
# NTFY_SERVER=https://ntfy.sh
# Optional: access token for a protected/self-hosted topic (Bearer auth)
# NTFY_TOKEN=tk_YOUR_TOKEN_HERE
